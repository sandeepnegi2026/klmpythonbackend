# Environments
.venv/
env/

# IDEs
.cursor/
.idea/
.vscode/

# Cache
__pycache__/
*.pyc

# Local Data / Tests / Scripts
# NOTE: data/, tests/, and scripts/ are SOURCE and stay tracked — they hold the
# product_master catalog, the pytest/regression harness (baselines/), and the
# real batch/triage pipeline scripts. Only their regenerated junk is ignored below.

# scripts/: keep .py/.sh source + config/manifest JSON; ignore scratch artifacts
scripts/__pycache__/
scripts/*.log
scripts/*.skipped.txt
scripts/_*.json
scripts/_*.txt
scripts/_synonym_spellings_cache*.json
scripts/unmapped_headers.json

# --- Added by gitignore hardening ---

# Python bytecode / caches (recursive)
**/__pycache__/
**/*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pytype/
.dmypy.json

# Virtual environments (extra names)
venv/
ENV/

# Build / packaging output
build/
dist/
*.egg-info/
.eggs/
wheels/

# Coverage / test reports
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/
nosetests.xml

# Generated triage/extraction working dirs (regenerated by the harness)
_extract_cache/
_triage/
_triage_after/
_triage_full/
scratch/

# Generated diagnostic report (rebuilt by scripts/build_header_synonyms.py)
unmapped_headers.json

# Logs
*.log

# Secrets / credentials (never commit)
.env
.env.*
!.env.example
!.env.sample
*.key
*.pem
*.p12
*.pfx
secrets.*
credentials.json
service-account*.json

# Large archives / binaries
*.rar
*.zip
*.7z
*.tar
*.tar.gz
*.tgz
*.gz

# OS cruft
.DS_Store
._*
Thumbs.db
ehthumbs.db
desktop.ini

# Jupyter / IPython
.ipynb_checkpoints/
profile_default/
ipython_config.py
